# ============================================================================
# CollegeOS — Environment Variables
# ============================================================================
# Copy this file to .env and replace the values with your own.
# Never commit your .env file to version control.
# ============================================================================

# ─── Application ─────────────────────────────────────────────────────────────
APP_NAME=collegeos
APP_ENV=development
APP_DEBUG=true
APP_VERSION=1.0.0

# ─── Database (PostgreSQL) ───────────────────────────────────────────────────
DB_USER=collegeos
DB_PASSWORD=collegeos
DB_NAME=collegeos
DB_PORT=5432
DATABASE_URL=postgresql+asyncpg://collegeos:collegeos@db:5432/collegeos

# ─── Redis ───────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0
REDIS_PORT=6379

# ─── Authentication (JWT) ───────────────────────────────────────────────────
JWT_SECRET=change-me-to-a-secure-random-string
JWT_ALGORITHM=HS256
JWT_EXPIRATION_MINUTES=60

# ─── NextAuth ────────────────────────────────────────────────────────────────
NEXTAUTH_URL=http://localhost
NEXTAUTH_SECRET=change-me-to-a-secure-random-string

# ─── CORS ────────────────────────────────────────────────────────────────────
BACKEND_CORS_ORIGINS=http://localhost:3000,http://localhost,http://localhost:80

# ─── Celery ──────────────────────────────────────────────────────────────────
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# ─── Service Ports ───────────────────────────────────────────────────────────
FRONTEND_PORT=3000
BACKEND_PORT=8000

# ─── Development ─────────────────────────────────────────────────────────────
AUTH_DISABLED=true

# ─── SMTP (optional) ────────────────────────────────────────────────────────
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM=noreply@collegeos.dev
